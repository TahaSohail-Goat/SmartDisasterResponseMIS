# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# IMPORTANT: Copy this file to .env and fill in YOUR values
# DO NOT commit .env file to GitHub!

# SQL Server hostname or IP address
# localhost = your local machine
# If SQL Server is on another computer, use the IP (e.g., 192.168.1.100)
DB_SERVER=localhost

# SQL Server username
# Common values: sa, admin, your_username
# Get this from your SQL Server administrator
DB_USER=your_sql_username

# SQL Server password
# Use the password you set when installing SQL Server
# KEEP THIS SECRET - never share with others
DB_PASSWORD=your_sql_password

# Database name
# You can change this to any name you want
# The ProjectDB.sql script will create this database
DB_DATABASE=ProjectDB

# SQL Server port (usually 1433)
DB_PORT=1433

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# Port where Node.js server will run
# Default: 5000
# If port 5000 is in use, change this to 5001, 5002, etc.
PORT=5000

# Environment mode
# development = verbose logging, no optimization
# production = optimized for deployment
NODE_ENV=development

# JWT authentication
# Generate a long random string for real deployments
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# Frontend origin for CORS in production. Use * for local development.
CORS_ORIGIN=*
